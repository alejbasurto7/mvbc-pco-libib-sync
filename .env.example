# PCO Personal Access Token (Basic auth)
PCO_APP_ID=
PCO_SECRET=

# Libib API credentials
LIBIB_API_KEY=
LIBIB_API_USER=

# Gmail SMTP credentials (App Password — requires 2FA enabled on the Gmail account)
GMAIL_USER=
GMAIL_APP_PASSWORD=

# Optional: display name + From address override. Defaults to GMAIL_USER if unset.
# Example: EMAIL_FROM="MVBC Library <alejandrobasurto7@gmail.com>"
EMAIL_FROM=
EMAIL_REPLY_TO=
EMAIL_BACKEND=gmail

# Behavior
STABILITY_HOURS=24
LIBIB_LOGIN_URL=https://www.libib.com/u/mvbchurch
BASELINE_MODE=false

# Comma-separated Libib tags that grant library access regardless of PCO state.
# Patrons with any of these tags are never auto-frozen.
PROTECTED_TAGS=ssm
